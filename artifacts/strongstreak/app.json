{
  "expo": {
    "name": "StrongStreak",
    "slug": "strongstreak",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "strongstreak",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1629"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.base69c726762a424892bc419135.app",
      "buildNumber": "29",
      "infoPlist": {
        "NSCameraUsageDescription": "StrongStreak needs camera access to let you take photos for your workout posts.",
        "NSPhotoLibraryUsageDescription": "StrongStreak needs photo library access to let you pick photos for your workout posts.",
        "NSPhotoLibraryAddUsageDescription": "StrongStreak needs permission to save photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.base69c726762a424892bc419135.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "StrongStreak needs photo library access to let you pick photos for your workout posts.",
          "cameraPermission": "StrongStreak needs camera access to let you take photos for your workout posts."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF4500"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "1b35884e-c01b-4f95-b3c3-54a1de878b26"
      }
    },
    "owner": "hamzashana"
  }
}
